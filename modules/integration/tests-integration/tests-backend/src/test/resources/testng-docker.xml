<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >

<!--
    TestNG suite for Docker-based integration tests.
    Uses Testcontainers instead of Carbon TAF to manage the WSO2 IS lifecycle.

    Differences from testng.xml:
    - No Carbon TAF listeners (TestExecutionListener, TestManagerListener, etc.)
    - DockerContainerInitializerTestCase replaces IdentityServerTestSuitInitializerTestCase
    - TomcatInitializerTestCase and LDAPServerInitializerTestCase remain (they run in-JVM)
    - Same test classes — they work in both Docker and legacy modes

    Usage: mvn clean install -DdockerTests
-->
<suite name="Docker-IS-suite" parallel="false" thread-count="1">
    <parameter name="useDefaultListeners" value="false"/>
    <listeners>
        <!-- Docker-compatible listeners only — no Carbon TAF listeners -->
        <listener class-name="org.wso2.identity.integration.test.listeners.DockerContainerListener"/>
        <listener class-name="org.wso2.identity.integration.test.listeners.IdentityTestListener"/>
        <listener class-name="org.wso2.identity.integration.test.base.SMTPServerInitializerListener"/>
    </listeners>

    <test name="docker-init" preserve-order="true" parallel="false" group-by-instances="true">
        <classes>
            <class name="org.wso2.identity.integration.test.base.DockerContainerInitializerTestCase"/>
            <class name="org.wso2.identity.integration.test.IdentityServerTestSuitInitializerTestCase"/>
            <class name="org.wso2.identity.integration.test.base.TomcatInitializerTestCase"/>
            <class name="org.wso2.identity.integration.test.base.LDAPServerInitializerTestCase"/>
        </classes>
    </test>

